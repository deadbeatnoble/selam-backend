# PostgreSQL (create database "selammind" in pgAdmin first)
DATABASE_URL=postgresql+psycopg://postgres:postgresql@localhost:5432/selammind

# SQLite fallback (uncomment to use instead of PostgreSQL)
# DATABASE_URL=sqlite:///./selammind.db

SECRET_KEY=your-secret-key-change-in-production
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Email notifications to doctors (optional — logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=selammind@yourdomain.com
SMTP_USE_TLS=true
